{
    "name": "nextjs",
    "description": "Next.js, Tailwind, @solana/react-hooks",
    "keywords": [
        "kit",
        "nextjs",
        "react",
        "solana-kit",
        "tailwind",
        "typescript"
    ],
    "create-solana-dapp": {
        "rename": {
            "scaffold": {
                "to": "{{name}}",
                "paths": [
                    "app"
                ]
            }
        }
    },
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "next build",
        "ci": "npm run build && npm run lint && npm run format:check",
        "dev": "next dev",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint",
        "start": "next start",
        "test": "vitest run && playwright test",
        "test:unit": "vitest",
        "test:unit:run": "vitest run",
        "test:unit:ui": "vitest --ui",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui"
    },
    "dependencies": {
        "@base-ui/react": "^1.4.1",
        "@better-auth-ui/core": "^1.6.8",
        "@better-auth-ui/react": "^1.6.8",
        "@better-auth/drizzle-adapter": "^1.6.11",
        "@better-auth/passkey": "^1.6.11",
        "@elysiajs/cors": "^1.4.2",
        "@elysiajs/openapi": "^1.4.15",
        "@elysiajs/server-timing": "^1.4.1",
        "@logtape/elysia": "^2.1.0",
        "@logtape/logtape": "^2.1.0",
        "@noble/hashes": "^2.2.0",
        "@solana/client": "^1.2.0",
        "@solana/react-hooks": "^1.1.5",
        "@solana/web3.js": "^1.98.4",
        "@t3-oss/env-nextjs": "^0.13.11",
        "@tanstack/react-pacer": "^0.22.1",
        "@tanstack/react-query": "^5.100.10",
        "better-auth": "^1.6.11",
        "bowser": "^2.14.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "elysia": "^1.4.28",
        "lucide-react": "^1.16.0",
        "motion": "^12.38.0",
        "next": "16.1.7",
        "next-themes": "^0.4.6",
        "nextjs-toploader": "^3.9.17",
        "nuqs": "^2.8.9",
        "pg": "^8.20.0",
        "postgres": "^3.4.9",
        "react": "19.2.3",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.3",
        "shadcn": "^4.7.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "ws": "^8.18.3",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@playwright/test": "^1.60.0",
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/pg": "^8.20.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitest/ui": "^4.1.6",
        "drizzle-kit": "^0.31.10",
        "eslint": "^9",
        "eslint-config-next": "16.0.10",
        "jsdom": "^29.1.1",
        "playwright": "^1.60.0",
        "prettier": "^3.6.2",
        "tailwindcss": "^4",
        "tsx": "^4.22.1",
        "typescript": "^5",
        "vitest": "^4.1.6"
    }
}
