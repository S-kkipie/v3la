{
  "name": "nextjs",
  "description": "Next.js, Tailwind, @solana/react-hooks",
  "keywords": [
    "kit",
    "nextjs",
    "react",
    "solana-kit",
    "tailwind",
    "typescript"
  ],
  "create-solana-dapp": {
    "rename": {
      "scaffold": {
        "to": "{{name}}",
        "paths": [
          "app"
        ]
      }
    }
  },
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "ci": "npm run build && npm run lint && npm run format:check",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "start": "next start"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dynamic-labs/sdk-react-core": "^4.83.1",
    "@dynamic-labs/solana": "^4.83.1",
    "@solana/client": "^1.2.0",
    "@solana/react-hooks": "^1.1.5",
    "@t3-oss/env-nextjs": "^0.13.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
